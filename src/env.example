# ── Google Calendar ───────────────────────────────────────────────────────────
# Option A: simple API key (works for public calendars)
GOOGLE_API_KEY=AIza...your_key_here
GOOGLE_CALENDAR_ID=primary

# Option B: OAuth2 static token (expires ~1h, quick testing only)
# GOOGLE_OAUTH_TOKEN=ya29.your_oauth_token

# Option C: OAuth2 refresh token (RECOMMENDED – auto-refreshes, never expires)
# Get these from Google Cloud Console → Credentials → OAuth 2.0 Client ID
# Then run the python snippet in the README to obtain the refresh token
# GOOGLE_REFRESH_TOKEN=1//0g...
# GOOGLE_CLIENT_ID=123...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── Weather (Open-Meteo, free, no key needed) ─────────────────────────────────
WEATHER_LAT=48.8566
WEATHER_LON=2.3522

# ── Server ────────────────────────────────────────────────────────────────────
BIND=0.0.0.0:3000

# ── Optional TRMNL API key (protects /display route) ─────────────────────────
# TRMNL_API_KEY=your_secret_key

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=trmnl_display=info,tower_http=debug
